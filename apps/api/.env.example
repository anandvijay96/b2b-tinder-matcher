# Database (self-hosted libSQL Server via Dokploy)
# Local dev: http://localhost:8080 (no auth)
# Dokploy internal: http://libsql:8080
# Dokploy external: https://db.yourdomain.com
LIBSQL_URL=http://localhost:8080
LIBSQL_AUTH_TOKEN=

# Auth
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string
ALLOWED_ORIGINS=http://localhost:8081,exp://localhost:8081

# Server
PORT=3000

# Email (SMTP — Mailpit for dev, Postal/relay for prod)
# Local dev: localhost:1025 (Mailpit Docker)
# Dokploy internal: mailpit:1025
SMTP_HOST=localhost
SMTP_PORT=1025
FROM_EMAIL=noreply@nmqmatch.com
