# =============================================================================
# NMQ B2B Match — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# For Dokploy: set these in the Environment tab of your Docker Compose project.

# ---- Database (libSQL Server) ----
# Public key for libSQL JWT auth (set on the libSQL server container)
LIBSQL_PUBLIC_KEY=
# JWT token for API → libSQL authentication (generated with gen-keys.mjs)
LIBSQL_AUTH_TOKEN=

# ---- Auth ----
# Secret for Better-Auth session signing (generate: openssl rand -base64 32)
BETTER_AUTH_SECRET=

# ---- CORS ----
# Comma-separated allowed origins for the API
ALLOWED_ORIGINS=http://localhost:8081,exp://localhost:8081

# ---- Email / OTP ----
# Dev/staging: use Mailpit (default values below work out of the box)
# Production: use a real SMTP relay (Brevo, SendGrid, AWS SES, etc.)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@nmqmatch.com

# ---- Production SMTP Examples ----
# Brevo (free tier: 300 emails/day, no credit card):
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=your-brevo-login@email.com
#   SMTP_PASS=your-brevo-smtp-key
#
# SendGrid (free tier: 100 emails/day):
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=apikey
#   SMTP_PASS=your-sendgrid-api-key
